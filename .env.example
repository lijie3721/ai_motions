# Aliyun DashScope / Qwen TTS. Fill this to use cloud voiceover instead of macOS say.
DASHSCOPE_API_KEY=your_dashscope_api_key

# Optional: voice model. UI voice presets are used by default.
ALIYUN_TTS_MODEL=qwen3-tts-instruct-flash

# Optional advanced override. Only set FORCE=1 when you intentionally want to ignore UI voice/style choices.
# ALIYUN_TTS_VOICE=Cherry
# ALIYUN_TTS_VOICE_FORCE=1
# ALIYUN_TTS_INSTRUCTION=English male commercial voiceover, confident and clear.
# ALIYUN_TTS_INSTRUCTION_FORCE=1

# Optional: stock video providers. Without these, the app still uses local/fallback media.
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Optional: OpenAI TTS settings. The current local MVP keeps this disabled unless both values are set.
OPENAI_API_KEY=
OPENAI_TTS_MODEL=

# Optional: local server port.
PORT=4173

# Optional: maximum request body size in bytes. Default is 50 MB.
MAX_UPLOAD_BYTES=52428800
