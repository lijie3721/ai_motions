# 普通用户建议直接在网页右上角的「配置中心」填写，不需要手动改这个文件。
# 这个文件只是给开发者参考：复制为 .env 后也可以手动填写。

# 阿里 DashScope：用于理解需求、生成脚本和配音。建议优先配置。
DASHSCOPE_API_KEY=your_dashscope_api_key

# 阿里 TTS 模型：一般保持默认即可。
ALIYUN_TTS_MODEL=qwen3-tts-instruct-flash

# 高级配音覆盖选项。普通用户不要改，页面里的配音选择会自动生效。
# 只有你明确想用环境变量强制覆盖页面选择时，才把 FORCE 改成 1。
# ALIYUN_TTS_VOICE=Cherry
# ALIYUN_TTS_VOICE_FORCE=1
# ALIYUN_TTS_INSTRUCTION=标准普通话，年轻有活力的商业宣传口播。
# ALIYUN_TTS_INSTRUCTION_FORCE=1

# 真实素材库：可选。填写后会搜索更多真实图片/视频素材。
PEXELS_API_KEY=
PIXABAY_API_KEY=

# OpenAI TTS 预留配置：当前本地 MVP 还没有真正接通 OpenAI TTS。
OPENAI_API_KEY=
OPENAI_TTS_MODEL=

# 本地服务端口。
PORT=4173

# 最大上传大小，单位是字节。默认 50MB。
MAX_UPLOAD_BYTES=52428800
